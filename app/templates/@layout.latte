<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{ifset title}{$title} | {/ifset}{$appName}</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="{$basePath}/css/app.css">
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container-fluid">
        <a class="navbar-brand fw-bold" n:href="Dashboard:">
            <i class="bi bi-cash-coin me-2"></i>Pokutovník
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarMain">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link {ifCurrent Dashboard:}active{/ifCurrent}" n:href="Dashboard:">
                        <i class="bi bi-speedometer2 me-1"></i>Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {ifCurrent Penalty:}active{/ifCurrent}" n:href="Penalty:">
                        <i class="bi bi-list-ul me-1"></i>Pokuty
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {ifCurrent User:}active{/ifCurrent}" n:href="User:">
                        <i class="bi bi-people me-1"></i>Uživatelé
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {ifCurrent PenaltyType:}active{/ifCurrent}" n:href="PenaltyType:">
                        <i class="bi bi-tags me-1"></i>Typy pokut
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {ifCurrent Fund:}active{/ifCurrent}" n:href="Fund:">
                        <i class="bi bi-piggy-bank me-1"></i>Fond
                    </a>
                </li>
            </ul>
        </div>
    </div>
</nav>

<div class="container-fluid py-3">

    {* Flash messages *}
    {foreach $flashes as $flash}
        <div class="alert alert-{$flash->type} alert-dismissible fade show" role="alert">
            {$flash->message}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {/foreach}

    {include content}

</div>

<footer class="bg-dark text-secondary text-center py-2 mt-4">
    <small>&copy; {date('Y')} Pokutovník</small>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script src="{$basePath}/js/app.js"></script>
{block scripts}{/block}
</body>
</html>
